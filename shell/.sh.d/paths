#!/usr/bin/env bash

# Default paths (can be overridden in paths.local)
PATHS_FIRST=(
  "${HOME}/.local/bin"
)

PATHS_LAST=(
  # e.g. /opt/apps
)

# Optional local override
LOCAL_FILE="${HOME}/.sh.d/paths.local"
if [[ -f "${LOCAL_FILE}" ]]; then
  # shellcheck source=/dev/null
  . "${LOCAL_FILE}"
fi

# _add_path <first|last> <path...>
_add_path() {
  local position="${1}"
  shift

  for p in "${@}"; do
    # Skip if path is already included
    [[ ":${PATH}:" == *":${p}:"* ]] && continue

    if [[ "${position}" == first ]]; then
      PATH="${p}:${PATH}"
    else
      PATH="${PATH}:${p}"
    fi
  done
}

_add_path first "${PATHS_FIRST[@]}"
_add_path last "${PATHS_LAST[@]}"

export PATH
